# ============================================================
# Revenue Retention OS — 환경변수 템플릿
# 이 파일을 .env.local 로 복사 후 실제 값을 입력하세요
# .env.local 은 절대 git에 커밋하지 마세요
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Supabase 프로젝트 대시보드 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 서버 전용 — 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# CLI용 (npm run db:types 등)
SUPABASE_PROJECT_ID=your-project-id

# ── 앱 설정 ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Super Admin 화이트리스트 ──────────────────────────────
# 쉼표로 구분하여 여러 계정 등록 가능
SUPER_ADMIN_EMAILS=superadmin@your-domain.com

# ── 보안 ─────────────────────────────────────────────────
# 초대 토큰 HMAC 서명 키 — 최소 32자 이상의 랜덤 문자열
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INVITE_TOKEN_SECRET=your-random-32-char-secret-here

# ── 이메일 발송 (선택 — 초대 메일용) ──────────────────────
# Resend 사용 권장: https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@your-domain.com

# ── 메시지 발송 연동 (테넌트별 설정은 api_integrations 테이블) ──
# 아래는 시스템 기본값 (테넌트 설정이 없을 때 폴백)
# SOLAPI_API_KEY=...
# SOLAPI_API_SECRET=...
